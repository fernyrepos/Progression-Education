<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ScenarioDef[defName="TheGravship"]/scenario/parts</xpath>
    <value>
			<li Class="ProgressionEducation.ScenPart_ForcedProficiencyTrait">
				<def>PE_ForcedProficiencyTrait</def>
				<chance>1</chance>
				<context>PlayerStarter</context>
				<trait>PE_HighTechProficiency</trait>
			</li>
			<li Class="ProgressionEducation.ScenPart_ForcedProficiencyTrait">
				<def>PE_ForcedProficiencyTrait</def>
				<chance>1</chance>
				<context>PlayerStarter</context>
				<trait>PE_OrbitalPilotingProficiency</trait>
			</li>
    </value>
  </Operation>


  <Operation Class="PatchOperationAddModExtension">
    <xpath>Defs/ResearchProjectDef[defName="Shuttles"]</xpath>
    <value>
      <li Class="ProgressionEducation.ResearchGrantsTrait">
        <trait>PE_OrbitalPilotingProficiency</trait>
        <title>Orbital piloting proficiency</title>
        <desc>Your intellectual has been bestowed the understanding of how to operate orbital vehicles. Other colonists can now be taught this knowledge in proficiency classes.</desc>
      </li>
    </value>
  </Operation>


</Patch>