<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="BuildingBase">
    <defName>PE_Projector</defName>
    <label>projector</label>
    <description>A classroom projector that can be linked to a learning board to improve learning effectiveness.</description>
    <thingClass>Building</thingClass>
    <graphicData>
      <texPath>Buildings/Tools/LearningProjector</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <altitudeLayer>BuildingOnTop</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.2</fillPercent>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>1200</WorkToBuild>
      <Flammability>0.5</Flammability>
      <Mass>5</Mass>
    </statBases>
    <size>(1,1)</size>
    <costList>
      <Steel>50</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <building>
      <isEdifice>false</isEdifice>
    </building>
    <designationCategory>Ferny_Education</designationCategory>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsMisc</li>
    </thingCategories>
    <tickerType>Normal</tickerType>
    <researchPrerequisites>
      <li>Ferny_IndustrialEducation</li>
    </researchPrerequisites>
    <placeWorkers>
      <li>PlaceWorker_ShowFacilitiesConnections</li>
    </placeWorkers>
    <soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
    <leaveResourcesWhenKilled>true</leaveResourcesWhenKilled>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>40</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable" />
      <li Class="CompProperties_Facility">
        <compClass>CompFacility</compClass>
        <maxSimultaneous>1</maxSimultaneous>
        <statOffsets>
          <PE_ClassSpeed>0.2</PE_ClassSpeed>
        </statOffsets>
      </li>
      <li Class="CompProperties_Glower">
        <glowRadius>8</glowRadius>
        <glowColor>(214,148,94,0)</glowColor>
        <colorPickerEnabled>true</colorPickerEnabled>
        <darklightToggle>true</darklightToggle>
      </li>
    </comps>
  </ThingDef>
</Defs>