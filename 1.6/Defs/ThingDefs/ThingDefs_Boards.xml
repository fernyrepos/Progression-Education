<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="BuildingBase">
        <defName>PE_LessonStone</defName>
        <label>lesson stone</label>
        <description>An ascetic surface for teaching lessons. Placing a board marks the area as a classroom, which can then be assigned classes.</description>
        <graphicData>
            <texPath>Buildings/LessonBoards/Lessonstone</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <shaderType>Cutout</shaderType>
            <drawSize>1.9</drawSize>
            <damageData>
                <rectN>(0.1, 0.3, 1.8, 0.5)</rectN>
                <rectS>(0.1, 0.3, 1.8, 0.5)</rectS>
                <rectE>(0.45, 0, 0.2, 1)</rectE>
                <rectW>(0.55, 0, 0.2, 1)</rectW>
            </damageData>
            <shadowData>
                <volume>(2, 0.5, 0.2)</volume>
            </shadowData>
        </graphicData>
        <descriptionHyperlinks>
            <ThingDef>PE_StoneSchoolDesk</ThingDef>
        </descriptionHyperlinks>
        <uiOrder>1</uiOrder>
        <altitudeLayer>Building</altitudeLayer>
        <designationCategory>Ferny_Education</designationCategory>
        <minifiedDef>MinifiedThing</minifiedDef>
        <defaultPlacingRot>South</defaultPlacingRot>
        <thingCategories>
            <li>BuildingsFurniture</li>
        </thingCategories>
        <passability>PassThroughOnly</passability>
        <canOverlapZones>false</canOverlapZones>
        <pathCost>50</pathCost>
        <fillPercent>0.5</fillPercent>
        <statBases>
            <MaxHitPoints>80</MaxHitPoints>
            <WorkToBuild>700</WorkToBuild>
            <Mass>10</Mass>
            <Flammability>0</Flammability>
            <Beauty>-3</Beauty>
            <PE_ClassSpeed>0.8</PE_ClassSpeed>
        </statBases>
        <researchPrerequisites>
            <li>Stonecutting</li>
        </researchPrerequisites>
        <size>(2,1)</size>
        <costStuffCount>15</costStuffCount>
        <stuffCategories>
            <li>Stony</li>
        </stuffCategories>
        <placeWorkers>
            <li>PlaceWorker_ShowFacilitiesConnections</li>
            <li>ProgressionEducation.PlaceWorker_SingleLearningBoard</li>
        </placeWorkers>
        <building>
            <paintable>false</paintable>
        </building>
        <comps>
            <li Class="ProgressionEducation.CompProperties_LearningBoard" />
            <li Class="CompProperties_AffectedByFacilities">
                <linkableFacilities>
                    <li>PE_Projector</li>
                </linkableFacilities>
            </li>
        </comps>
    </ThingDef>

