    <generationTechLevel>Spacer</generationTechLevel>
    <legacyNames>
      <li>HighTech</li>
    </legacyNames>
  </ProgressionEducation.ProficiencyTierDef>

  <ProgressionEducation.ProficiencyTierDef MayRequire="MemeGoddess.GiddyUp">
