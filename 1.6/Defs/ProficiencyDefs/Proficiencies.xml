    <iconPath>UI/ProficiencyIcons/Vehicle/Automobile</iconPath>
    <semesterGoal>30000</semesterGoal>
    <generationTechLevel>Industrial</generationTechLevel>
  </ProgressionEducation.ProficiencyTierDef>

  <ProgressionEducation.ProficiencyTierDef MayRequire="SmashPhil.VehicleFramework">
