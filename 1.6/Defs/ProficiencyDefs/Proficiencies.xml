<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ProgressionEducation.ProficiencyDef>
    <defName>PE_WeaponTrack</defName>
    <label>weapon</label>
    <tiers>
      <li>PE_LowTechTier</li>
      <li>PE_FirearmTier</li>
      <li>PE_HighTechTier</li>
    </tiers>
  </ProgressionEducation.ProficiencyDef>

  <ProgressionEducation.ProficiencyDef>
    <defName>PE_VehicleTrack</defName>
    <label>vehicle</label>
    <tiers>
      <li MayRequire="MemeGoddess.GiddyUp">PE_AnimalRidingTier</li>
      <li MayRequire="SmashPhil.VehicleFramework">PE_AutomobileDrivingTier</li>
      <li MayRequire="SmashPhil.VehicleFramework">PE_AerialPilotingTier</li>
      <li MayRequire="ludeon.rimworld.odyssey">PE_OrbitalPilotingTier</li>
    </tiers>
  </ProgressionEducation.ProficiencyDef>

  <ProgressionEducation.ProficiencyDef>
    <defName>PE_SpeechTrack</defName>
    <label>speech</label>
    <tiers>
      <li>PE_MuteTier</li>
      <li>PE_BasicSpeechTier</li>
      <li>PE_FluentSpeechTier</li>
    </tiers>
  </ProgressionEducation.ProficiencyDef>

  <ProgressionEducation.ProficiencyTierDef>
    <defName>PE_LowTechTier</defName>
    <label>low-tech</label>
    <traitDef>PE_LowTechProficiency</traitDef>
    <iconPath>UI/ProficiencyIcons/Weapon/LowTech</iconPath>
    <generationTechLevel>Neolithic</generationTechLevel>
  </ProgressionEducation.ProficiencyTierDef>

  <ProgressionEducation.ProficiencyTierDef>
    <defName>PE_FirearmTier</defName>
    <label>firearm</label>
    <traitDef>PE_FirearmProficiency</traitDef>
    <iconPath>UI/ProficiencyIcons/Weapon/Firearm</iconPath>
